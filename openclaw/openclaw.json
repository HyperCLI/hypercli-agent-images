{
  "models": {
    "mode": "merge",
    "providers": {
      "hyperclaw": {
        "baseUrl": "${HYPER_AGENTS_API_BASE}",
        "apiKey": "${HYPER_AGENTS_API_KEY}",
        "api": "anthropic-messages",
        "authHeader": true,
        "models": [
          {
            "id": "kimi-k2.6-anthropic",
            "name": "Kimi K2.6",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 262144,
            "maxTokens": 262144
          }
        ]
      }
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "${OPENCLAW_CONTROL_UI_ALLOWED_ORIGIN}"
      ]
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "model": {
        "primary": "hyperclaw/kimi-k2.6-anthropic"
      },
      "models": {
        "hyperclaw/kimi-k2.6-anthropic": {
          "alias": "kimi"
        }
      },
      "memorySearch": {
        "provider": "openai",
        "model": "qwen3-embedding-4b",
        "remote": {
          "baseUrl": "${HYPER_AGENTS_API_BASE}/v1",
          "apiKey": "${HYPER_AGENTS_API_KEY}"
        }
      }
    },
    "list": [
      {
        "id": "default",
        "name": "OpenClaw Assistant",
        "workspace": "~/.openclaw/workspace"
      }
    ]
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "cron": {
    "enabled": false
  },
  "plugins": {
    "entries": {
      "brave": {
        "enabled": true,
        "config": {
          "webSearch": {
            "baseUrl": "${HYPER_AGENTS_WEB_SEARCH_BASE}",
            "apiKey": "${HYPER_AGENTS_API_KEY}"
          }
        }
      }
    }
  },
  "tools": {
    "web": {
      "search": {
        "enabled": true,
        "provider": "brave"
      }
    }
  }
}
